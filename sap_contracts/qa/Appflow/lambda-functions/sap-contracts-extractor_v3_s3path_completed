import json
import boto3
import urllib.request
import urllib.parse
import base64
import time
import os
import logging
from datetime import datetime, timedelta
from concurrent.futures import ThreadPoolExecutor, as_completed

MAX_WORKERS    = 20
RETRY_COUNT    = 3
BACKOFF_FACTOR = 2
API_TIMEOUT    = 60
BRONZE_BUCKET  = "epiq-edp-dl-qa-bronze"

logger = logging.getLogger()
logger.setLevel(logging.INFO)


def get_sap_credentials(env):
    client = boto3.client('secretsmanager', region_name='us-east-1')
    secret_id = "sap/qa/contracts_api/credentials" if env == "qa" else "sap/dev/odata/credentials"
    print(f"Using secret: {secret_id}")
    secret = client.get_secret_value(SecretId=secret_id)
    return json.loads(secret['SecretString'])


def call_sap_api(url, username, password):
    credentials = base64.b64encode(f"{username}:{password}".encode()).decode()
    req = urllib.request.Request(url)
    req.add_header('Authorization', f'Basic {credentials}')
    req.add_header('Accept', 'application/json')
    with urllib.request.urlopen(req, timeout=API_TIMEOUT) as response:
        return json.loads(response.read().decode())


def get_cache_key(env, start_date, end_date):
    return f"sap/cache/contract_list_{env}_{start_date}_{end_date}.json"


def cache_exists(env, start_date, end_date):
    s3 = boto3.client('s3', region_name='us-east-1')
    try:
        s3.head_object(Bucket=BRONZE_BUCKET, Key=get_cache_key(env, start_date, end_date))
        print("Cache found")
        return True
    except:
        print("Cache not found")
        return False


def save_cache(contracts, env, start_date, end_date):
    s3 = boto3.client('s3', region_name='us-east-1')
    key = get_cache_key(env, start_date, end_date)
    s3.put_object(Bucket=BRONZE_BUCKET, Key=key, Body=json.dumps(contracts), ContentType='application/json')
    print(f"Cached: {key}")


def load_cache(env, start_date, end_date):
    s3 = boto3.client('s3', region_name='us-east-1')
    key = get_cache_key(env, start_date, end_date)
    obj = s3.get_object(Bucket=BRONZE_BUCKET, Key=key)
    print(f"Loaded cache: {key}")
    return json.loads(obj['Body'].read().decode())


def delete_cache(env, start_date, end_date):
    s3 = boto3.client('s3', region_name='us-east-1')
    key = get_cache_key(env, start_date, end_date)
    s3.delete_object(Bucket=BRONZE_BUCKET, Key=key)
    print(f"Cache deleted: {key}")


def write_to_s3_temp(data, env, entity, offset):
    s3 = boto3.client('s3', region_name='us-east-1')
    key = f"sap/temp/{entity}_{env}_{offset}.json"
    s3.put_object(Bucket=BRONZE_BUCKET, Key=key, Body=json.dumps(data), ContentType='application/json')
    print(f"Written to S3 temp: {key}")
    return key


def log_failed_contracts(failed_list, env, start_date, end_date):
    if not failed_list:
        return
    s3 = boto3.client('s3', region_name='us-east-1')
    key = f"sap/logs/failed_contracts_{env}_{start_date}_{end_date}.json"
    s3.put_object(Bucket=BRONZE_BUCKET, Key=key, Body=json.dumps({"failed_contracts": failed_list}), ContentType='application/json')
    print(f"Failed logged: {key}")


def get_watermark_date():
    athena = boto3.client('athena', region_name='us-east-1')
    query = """
        SELECT MAX(last_successful_watermark)
        FROM edp_configs_dev.edp_incremental_control
        WHERE table_name = 'contracts'
    """
    response = athena.start_query_execution(
        QueryString=query,
        ResultConfiguration={'OutputLocation': 's3://aws-athena-query-results-us-east-1-730878889077/'}
    )
    qid = response['QueryExecutionId']
    while True:
        status = athena.get_query_execution(QueryExecutionId=qid)
        state = status['QueryExecution']['Status']['State']
        if state in ['SUCCEEDED', 'FAILED', 'CANCELLED']:
            break
        time.sleep(2)
    if state != 'SUCCEEDED':
        raise Exception("Athena query failed")
    result = athena.get_query_results(QueryExecutionId=qid)
    watermark = result['ResultSet']['Rows'][1]['Data'][0].get('VarCharValue', None)
    if watermark and watermark != '':
        return (datetime.strptime(watermark[:10], '%Y-%m-%d') + timedelta(days=1)).strftime('%Y-%m-%d')
    else:
        return (datetime.now() - timedelta(days=30)).strftime('%Y-%m-%d')


def build_date_chunks(start_str, end_str):
    start = datetime.strptime(start_str, "%Y-%m-%d")
    end   = datetime.strptime(end_str, "%Y-%m-%d")
    chunks = []
    cs = start
    while cs <= end:
        ce = min(cs + timedelta(days=89), end)
        chunks.append((cs.strftime('%Y-%m-%d'), ce.strftime('%Y-%m-%d')))
        cs = ce + timedelta(days=1)
    return chunks


def get_contract_list(creds, start_date, end_date):
    base_url = creds['sap_base_url']
    sap_path = creds['sap_path']
    chunks   = build_date_chunks(start_date, end_date)
    all_contracts = []
    for (cs, ce) in chunks:
        for attr in ['CREATE', 'CHANGE']:
            fstr = f"ContractDate ge {cs} and ContractDate le {ce} and attribute eq '{attr}'"
            url = (
                f"{base_url}{sap_path}ZSD_API_CONTRACT_LIST"
                f"?$filter={urllib.parse.quote(fstr)}"
                f"&$select=ContractNumber,SalesOrganization,ContractDate,CreatedDate,ChangedDate,attribute"
                f"&$top=5000&$format=json"
            )
            try:
                resp = call_sap_api(url, creds['username'], creds['password'])
                recs = resp.get('value', [])
                print(f"{cs}→{ce} | {attr} | {len(recs)} records")
                for r in recs:
                    r['attribute'] = attr
                all_contracts.extend(recs)
            except Exception as e:
                print(f"Error {cs}→{ce} {attr}: {e}")
    print(f"Total contracts: {len(all_contracts)}")
    return all_contracts


def get_contract_details(cn, creds):
    url = (
        f"{creds['sap_base_url']}/sap/opu/odata4/sap/zsb_contracts_data_api/srvd_a2x/sap/zsd_contracts_data_api/0001/"
        f"ContractHeader('{cn}')?$expand=_ContractItems&$format=json"
    )
    return call_sap_api(url, creds['username'], creds['password'])


def get_contract_details_retry(cn, creds):
    delay = 2
    for attempt in range(1, RETRY_COUNT + 1):
        try:
            return get_contract_details(cn, creds)
        except Exception as e:
            print(f"Retry {attempt} for {cn}: {e}")
            if attempt == RETRY_COUNT:
                return None
            time.sleep(delay)
            delay *= BACKOFF_FACTOR


def fetch_details_parallel(contracts, creds, env, start_date, end_date):
    numbers = list(set([c.get('ContractNumber') for c in contracts if c.get('ContractNumber')]))
    total = len(numbers)
    all_details = []
    all_failed  = []
    bn = 0
    print(f"Fetching details for {total} contracts")
    for i in range(0, total, 10):
        batch = numbers[i:i+10]
        bn += 1
        print(f"Batch {bn}: {batch}")
        br = []
        bf = []
        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:
            futures = {ex.submit(get_contract_details_retry, cn, creds): cn for cn in batch}
            for f in as_completed(futures):
                cn = futures[f]
                r = f.result()
                if r:
                    br.append(r)
                    print(f"OK: {cn}")
                else:
                    bf.append(cn)
                    print(f"FAIL: {cn}")
        all_details.extend(br)
        all_failed.extend(bf)
        print(f"Batch {bn} — {len(br)}/{len(batch)} | Total: {len(all_details)}/{total}")
        if i + 10 < total:
            time.sleep(0.1)
    if all_failed:
        log_failed_contracts(all_failed, env, start_date, end_date)
    print(f"Done — {len(all_details)} ok | {len(all_failed)} failed")
    return all_details


def get_cached_contracts(creds, env, start_date, end_date):
    if cache_exists(env, start_date, end_date):
        return load_cache(env, start_date, end_date)
    else:
        contracts = get_contract_list(creds, start_date, end_date)
        save_cache(contracts, env, start_date, end_date)
        return contracts


def smart_return(data, env, entity, offset):
    body = json.dumps(data)
    size = len(body.encode('utf-8'))
    print(f"Response size: {size} bytes")
    if size > 5000000:
        print("Response > 5MB — using S3")
        key = write_to_s3_temp(data, env, entity, offset)
        return {
            'statusCode': 200,
            'body': json.dumps({'s3_key': key, 'has_more': data.get('has_more', False)})
        }
    else:
        print("Response < 5MB — returning direct")
        return {
            'statusCode': 200,
            'body': body
        }


def lambda_handler(event, context):
    print(f"==== EXTRACTOR START ====")
    print(f"EVENT: {json.dumps(event)}")

    try:
        env    = event.get('env', 'dev')
        entity = event.get('entity', '')
        offset = int(event.get('offset', 0))
        limit  = int(event.get('limit', int(os.environ.get("PAGE_SIZE", "75"))))
        creds  = get_sap_credentials(env)

        load_type = os.environ.get("LOAD_TYPE", "INCR").upper()
        if load_type == "FULL":
            start_date = os.environ.get("START_DATE")
            end_date   = os.environ.get("END_DATE")
            if not start_date or not end_date:
                raise Exception("START_DATE and END_DATE required")
            print(f"[FULL] {start_date} to {end_date}")
        else:
            start_date = get_watermark_date()
            end_date   = datetime.now().strftime('%Y-%m-%d')
            print(f"[INCR] {start_date} to {end_date}")

        print(f"ENV={env} | ENTITY={entity} | OFFSET={offset} | LIMIT={limit}")

        if offset == 0:
            try:
                delete_cache(env, start_date, end_date)
            except:
                pass

        all_contracts = get_cached_contracts(creds, env, start_date, end_date)

        if entity == "ContractList":
            page     = all_contracts[offset:offset+limit]
            has_more = (offset+limit) < len(all_contracts)
            print(f"Page: {len(page)} | has_more: {has_more}")
            if not has_more:
                delete_cache(env, start_date, end_date)
            return smart_return({'contract_list': {'value': page}, 'has_more': has_more}, env, entity, offset)

        elif entity == "ContractDetails":
            page_contracts = all_contracts[offset:offset+limit]
            has_more       = (offset+limit) < len(all_contracts)
            print(f"Contracts: {len(page_contracts)} | has_more: {has_more}")
            details = fetch_details_parallel(page_contracts, creds, env, start_date, end_date)
            if not has_more:
                delete_cache(env, start_date, end_date)
            return smart_return({'contract_details': details, 'has_more': has_more}, env, entity, offset)

        else:
            raise Exception(f"Unknown entity: {entity}")

    except Exception as e:
        print(f"Error: {str(e)}")
        return {'statusCode': 500, 'body': json.dumps({'error': str(e)})}